# --------------------------------------------------
# Database
# --------------------------------------------------
COMET_DB_HOST=127.0.0.1
COMET_DB_USERNAME=root
COMET_DB_PASSWORD=changeme
COMET_DB_NAME=pixel_comet

# Database pool
COMET_DB_POOL_MAX=100
COMET_DB_POOL_MIN=10
COMET_DB_POOL_COUNT=2
COMET_DB_POOL_IDLEMAXAGESECONDS=30
COMET_DB_POOL_MAXCONNECTIONAGESECONDS=60
COMET_DB_POOL_ACQUIRERETRYATTEMPTS=50
COMET_DB_POOL_AUTORECONNECT=false
COMET_DB_POOL_TCPKEEPALIVE=true
COMET_DB_SEED_ENABLED=true

# --------------------------------------------------
# Network
# --------------------------------------------------
COMET_NETWORK_HOST=0.0.0.0
COMET_NETWORK_PORT=2096
COMET_TRANSPORT_TCP_ENABLED=true
COMET_TRANSPORT_WEBSOCKETS_ENABLED=true
COMET_TRANSPORT_WEBSOCKETS_PORT=87
COMET_NETWORK_BACKLOG=1500
COMET_NETWORK_EPOLL=false
COMET_NETWORK_ACCEPTGROUPTHREADS=2
COMET_NETWORK_IOGROUPTHREADS=2
COMET_NETWORK_CHANNELGROUPTHREADS=4
COMET_NETWORK_MAXPACKETSIZE=500000

COMET_NETWORK_IDLETIMER_ENABLED=false
COMET_NETWORK_IDLETIMER_READERIDLETIME=60
COMET_NETWORK_IDLETIMER_WRITERIDLETIME=30
COMET_NETWORK_IDLETIMER_ALLIDLETIME=0

COMET_NETWORK_ALTERNATIVEPACKETHANDLING_ENABLED=false
COMET_NETWORK_ALTERNATIVEPACKETHANDLING_TYPE=threadpool
COMET_NETWORK_ALTERNATIVEPACKETHANDLING_CORESIZE=8
COMET_NETWORK_ALTERNATIVEPACKETHANDLING_MAXSIZE=32

# --------------------------------------------------
# Thread pools
# --------------------------------------------------
COMET_SYSTEM_THREADS=16
COMET_SYSTEM_TASKROOMTHREADS=8

# --------------------------------------------------
# Logging
# --------------------------------------------------
# Root log level: trace | debug | info | warn | error
LOG_LEVEL=info
# Output format: console | json
LOG_FORMAT=console

# --------------------------------------------------
# Game
# --------------------------------------------------
COMET_GAME_ROOMS_DATA_MAX=5000
COMET_GAME_ROOMS_DATA_LOWERWATERMARK=0
COMET_GAME_LOGGING_ENABLED=true
COMET_RECIBIDOR_ID=7211

# --------------------------------------------------
# Redis cache
# --------------------------------------------------
COMET_CACHE_PREFIX=comet
COMET_CACHE_CONNECTION_HOST=127.0.0.1
COMET_CACHE_CONNECTION_PORT=6379
COMET_SSO_TICKET_TTL_SECONDS=60
COMET_SSO_TICKET_KEY_PREFIX=sso
COMET_SSO_SESSION_TTL_SECONDS=43200
COMET_SSO_SESSION_KEY_PREFIX=session

# --------------------------------------------------
# REST management API
# --------------------------------------------------
COMET_API_ENABLED=false
COMET_API_TOKEN=replace_with_output_of_openssl_rand_hex_32
COMET_API_TOKEN_HEADER=X-API-Key
# The management API shares COMET_TRANSPORT_WEBSOCKETS_PORT with /game and /ws.
# Exposes /openapi/spec and /swagger when true.
COMET_API_DOCS_ENABLED=false

# --------------------------------------------------
# Connection registry
# --------------------------------------------------
COMET_CONNECTION_REGISTRY_IMPLEMENTATION=inmemory
COMET_CONNECTION_REGISTRY_TTLSECONDS=3600

# --------------------------------------------------
# Modules
# --------------------------------------------------
COMET_MODULES_DIR=./modules

# Module-specific values follow MODULE_<MODULE_NAME>_<KEY>.
# Built-in modules also accept the shortened form without a COMET_ prefix.
# Example:
# MODULE_GROUPS_CACHE_TTL_SECONDS=86400
